From 4d0a99931717131e271eb2c24de127e275530314 Mon Sep 17 00:00:00 2001
From: Bohdan Onofriichuk <bogdan.onofriuchuk@gmail.com>
Date: Wed, 14 Jan 2026 12:53:51 +0200
Subject: [PATCH] Fix launch when kmscon is used

Add kmscon to conflicts, otherwise plasma-login-manager is not started
if getty replaced with kmscon.
---
 services/plasmalogin.service.in | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/services/plasmalogin.service.in b/services/plasmalogin.service.in
index 134e9a6..d0e5443 100644
--- a/services/plasmalogin.service.in
+++ b/services/plasmalogin.service.in
@@ -1,8 +1,8 @@
 [Unit]
 Description=Plasma Login Manager
 Documentation=man:plasmalogin(1) man:plasmalogin.conf(5)
-Conflicts=getty@tty${PLASMALOGIN_INITIAL_VT}.service
-After=systemd-user-sessions.service getty@tty${PLASMALOGIN_INITIAL_VT}.service plymouth-quit.service systemd-logind.service
+Conflicts=getty@tty${PLASMALOGIN_INITIAL_VT}.service kmsconvt@tty${PLASMALOGIN_INITIAL_VT}.service
+After=systemd-user-sessions.service getty@tty${PLASMALOGIN_INITIAL_VT}.service kmsconvt@tty${PLASMALOGIN_INITIAL_VT}.service plymouth-quit.service systemd-logind.service
 PartOf=graphical.target
 StartLimitIntervalSec=30
 StartLimitBurst=2
-- 
2.53.0

